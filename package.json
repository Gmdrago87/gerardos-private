{
  "name": "gerardos-private",
  "version": "1.1.0",
  "description": "GerardOS Private Dashboard",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.wrangler/tmp', { recursive: true, force: true })\"",
    "prestart": "npm run clean",
    "start": "wrangler pages dev public --port 8789 --env-file .dev.vars",
    "build:db": "node generate.js",
    "predeploy": "node -e \"const fs=require('fs');const p='public/sw.js';const c=fs.readFileSync(p,'utf8');fs.writeFileSync(p,c.replace(/gerardos-v\\d+/,'gerardos-v'+Date.now()))\"",
    "deploy": "npm run predeploy && wrangler pages deploy public"
  },
  "devDependencies": {
    "wrangler": "^4.112.0"
  }
}
